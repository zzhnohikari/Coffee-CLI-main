{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Coffee CLI",
  "version": "2.1.3",
  "identifier": "com.coffeemode.desktop",
  "build": {
    "frontendDist": "./src-ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "",
    "beforeDevCommand": { "script": "npm run dev", "cwd": "./src-ui" }
  },

  "app": {
    "windows": [
      {
        "title": "Coffee CLI",
        "label": "main",
        "width": 1600,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "transparent": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Coffee Team",
    "resources": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
